<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="TOP_CENTER" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="600.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.sudokugame.controller.FinalController">
   <children>
      <Label fx:id="lbFinalMessage" text="Mensaje final" textFill="#1a00ff">
         <font>
            <Font name="Rockwell Bold" size="25.0" />
         </font>
         <VBox.margin>
            <Insets top="70.0" />
         </VBox.margin>
      </Label>
      <ImageView fitHeight="280.0" fitWidth="366.0" pickOnBounds="true" preserveRatio="true">
         <VBox.margin>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
         </VBox.margin>
      </ImageView>
      <HBox alignment="TOP_CENTER" prefHeight="100.0" prefWidth="200.0">
         <children>
            <Button fx:id="btExitGame" mnemonicParsing="false" onAction="#onActionExitGame" text="Salir del juego">
               <HBox.margin>
                  <Insets left="50.0" right="100.0" />
               </HBox.margin>
               <font>
                  <Font name="Tahoma Bold" size="14.0" />
               </font>
            </Button>
            <Button fx:id="btReplay" mnemonicParsing="false" onAction="#onActionReplay" text="volver a jugar">
               <HBox.margin>
                  <Insets left="100.0" right="50.0" />
               </HBox.margin>
               <font>
                  <Font name="Tahoma Bold" size="14.0" />
               </font>
            </Button>
         </children>
      </HBox>
   </children>
</VBox>
